\@writefile{lot}{\contentsline {table}{\numberline {II}{\ignorespaces Access performance under matched state/action across seven methods (mean $\pm $ std over ten seeds). At this compact, CPU-scale realization the learners are high-variance; we therefore read trends, not a single winner (see text).}}{11}{table.2}\protected@file@percent }
\newlabel{tab:metrics}{{II}{11}{Access performance under matched state/action across seven methods (mean $\pm $ std over ten seeds). At this compact, CPU-scale realization the learners are high-variance; we therefore read trends, not a single winner (see text)}{table.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Head-to-head comparison under a matched environment, state, and discrete action set (ten seeds, $\pm $ one standard deviation). At this compact CPU scale the mean throughput of the learners overlaps within one standard deviation; the robust reading is that the belief-state agents (Belief-DQN, LA-JSSA) hold lower mean collisions than the random and policy-gradient baselines, while the clean separation on \emph  {tail} risk appears in the CVaR study of Fig.~\ref {fig:cvartail}, not in the mean here.}}{11}{figure.2}\protected@file@percent }
\newlabel{fig:baselines}{{2}{11}{Head-to-head comparison under a matched environment, state, and discrete action set (ten seeds, $\pm $ one standard deviation). At this compact CPU scale the mean throughput of the learners overlaps within one standard deviation; the robust reading is that the belief-state agents (Belief-DQN, LA-JSSA) hold lower mean collisions than the random and policy-gradient baselines, while the clean separation on \emph {tail} risk appears in the CVaR study of Fig.~\ref {fig:cvartail}, not in the mean here}{figure.2}{}}
