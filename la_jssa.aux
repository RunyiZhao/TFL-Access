\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Validation of Theorem~\ref {thm:tradeoff}. \emph  {(a)} Empirically measured detector ROC ($1-P_{\mathrm  {md}}$ vs.\ $P_{\mathrm  {fa}}$). \emph  {(b)} PU-collision rate vs.\ belief threshold $\eta $; the feasibility frontier $\eta _{\min }$ is marked. \emph  {(c)} Throughput vs.\ $\eta $; the simulated optimum $\eta ^\star $ (dashed) coincides with the analytical optimum of \eqref  {eq:thmA_opt}.}}{12}{figure.3}\protected@file@percent }
\newlabel{fig:tradeoff}{{3}{12}{Validation of Theorem~\ref {thm:tradeoff}. \emph {(a)} Empirically measured detector ROC ($1-\Pmd $ vs.\ $\Pfa $). \emph {(b)} PU-collision rate vs.\ belief threshold $\thr $; the feasibility frontier $\thr _{\min }$ is marked. \emph {(c)} Throughput vs.\ $\thr $; the simulated optimum $\thr ^\star $ (dashed) coincides with the analytical optimum of \eqref {eq:thmA_opt}}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Distributional CVaR access (M1). Per-window PU-collision histogram: the expectation-constrained agent (red) has a heavy tail, while the CVaR-constrained agent (purple) clips it to near zero at comparable throughput, as predicted by Theorem~\ref {thm:cvar}.}}{12}{figure.4}\protected@file@percent }
\newlabel{fig:cvartail}{{4}{12}{Distributional CVaR access (M1). Per-window PU-collision histogram: the expectation-constrained agent (red) has a heavy tail, while the CVaR-constrained agent (purple) clips it to near zero at comparable throughput, as predicted by Theorem~\ref {thm:cvar}}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Component ablation. Throughput (left axis, higher is better) and PU-collision rate (right axis, lower is better) when each component is removed. Removing the belief state ($-$M2) or the uncertainty penalty ($-$M3) sharply degrades both metrics; $-$M1 matches \emph  {Full} in the mean but not in the tail (cf.\ Fig.~\ref {fig:cvartail}). Error bars are $\pm $ one standard deviation over seeds.}}{12}{figure.5}\protected@file@percent }
\newlabel{fig:ablation}{{5}{12}{Component ablation. Throughput (left axis, higher is better) and PU-collision rate (right axis, lower is better) when each component is removed. Removing the belief state ($-$M2) or the uncertainty penalty ($-$M3) sharply degrades both metrics; $-$M1 matches \emph {Full} in the mean but not in the tail (cf.\ Fig.~\ref {fig:cvartail}). Error bars are $\pm $ one standard deviation over seeds}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Frequency vs.\ temporal localization sensitivity. \emph  {(a)} Throughput and \emph  {(b)} PU-collision rate degrade steeply with frequency-localization error (red) but are nearly flat under temporal-localization error (blue), confirming that same-frame access depends on frequency, not time. Error bars are $\pm $ one standard deviation.}}{12}{figure.6}\protected@file@percent }
\newlabel{fig:freqtime}{{6}{12}{Frequency vs.\ temporal localization sensitivity. \emph {(a)} Throughput and \emph {(b)} PU-collision rate degrade steeply with frequency-localization error (red) but are nearly flat under temporal-localization error (blue), confirming that same-frame access depends on frequency, not time. Error bars are $\pm $ one standard deviation}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces From localization accuracy to access. \emph  {(a)} As localization error $\varepsilon _{\mathrm  {loc}}=1-\mathrm  {IoU}$ grows, the induced cell-level $P_{\mathrm  {md}},P_{\mathrm  {fa}}$ grow nearly linearly, validating \eqref  {eq:loc_to_cell}. \emph  {(b)} The access throughput gap grows linearly in $\varepsilon _{\mathrm  {loc}}$ (dashed: linear fit), validating Corollary~\ref {cor:loc}. Error bars are $\pm $ one standard deviation over seeds.}}{12}{figure.7}\protected@file@percent }
\newlabel{fig:localization}{{7}{12}{From localization accuracy to access. \emph {(a)} As localization error $\eloc =1-\mathrm {IoU}$ grows, the induced cell-level $\Pmd ,\Pfa $ grow nearly linearly, validating \eqref {eq:loc_to_cell}. \emph {(b)} The access throughput gap grows linearly in $\eloc $ (dashed: linear fit), validating Corollary~\ref {cor:loc}. Error bars are $\pm $ one standard deviation over seeds}{figure.7}{}}
